# Copy this file to .env and fill in your values
# Run: cp .env.example .env

# URL where the FastAPI backend is running
# If running locally: http://localhost:8000
# If deployed: https://your-backend-domain.com
EXPO_PUBLIC_BACKEND_URL=http://localhost:8000

# API key for the backend (can be any string — the backend doesn't validate it currently)
EXPO_PUBLIC_BACKEND_API_KEY=skillfit-local
