# Copy this file to .env and fill in your values
# Run: cp .env.example .env

# Sarvam AI — for STT (speech-to-text) and TTS (text-to-speech)
# Get your key at: https://dashboard.sarvam.ai
SARVAM_API_KEY=

# Groq — for the LLM (Llama 3.3 70B)
# Get your key at: https://console.groq.com
GROQ_API_KEY=

# LiveKit Cloud — for real-time voice rooms
# Get these from your LiveKit Cloud project at: https://cloud.livekit.io
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
